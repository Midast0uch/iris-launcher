<WixLocalization Culture="en-us" xmlns="http://schemas.microsoft.com/wix/2006/localization"><String Id="TauriLanguage">1033</String><String Id="TauriCodepage">1252</String><String Id="LaunchApp">Launch IRIS Launcher</String><String Id="DowngradeErrorMessage">A newer version of IRIS Launcher is already installed.</String><String Id="PathEnvVarFeature">Add the install location of the IRIS Launcher executable to the PATH system environment variable. This allows the IRIS Launcher executable to be called from any location.</String><String Id="InstallAppFeature">Installs IRIS Launcher.</String></WixLocalization>